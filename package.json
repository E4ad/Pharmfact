{
  "name": "pharmfact",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "server": "node server/index.js",
    "dev:server": "node server/index.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "qa:proxy": "vitest run server/proxy.test.js",
    "test:e2e": "playwright test",
    "screenshots": "node scripts/capture-ui.js",
    "screenshots:auto": "./scripts/run-captures.sh",
    "build:pharmacy-registry": "node scripts/build-sante-pharmacy-registry.mjs",
    "start": "vite",
    "lint": "eslint src/ server/ --ext .ts,.tsx,.js",
    "lint:fix": "eslint src/ server/ --ext .ts,.tsx,.js --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"server/**/*.js\"",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "test:coverage": "vitest run --coverage",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "package:dmg": "node scripts/package-macos-dmg.mjs",
    "tauri:build": "CI=true tauri build --bundles app && npm run package:dmg",
    "tauri:build:mac": "CI=true tauri build --target universal-apple-darwin --bundles app && DMG_ARCH=universal npm run package:dmg",
    "test:pdf": "node scripts/test-pdf-generation.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@vitejs/plugin-react": "^6.0.2",
    "date-fns": "^4.4.0",
    "file-type": "^22.0.1",
    "jspdf": "^4.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "uuid": "^14.0.0",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.60.0",
    "prom-client": "^15.1.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitejs/plugin-basic-ssl": "^2.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.8"
  }
}
